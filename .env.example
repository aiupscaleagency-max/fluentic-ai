# Google AI Studio-nyckel för chat, översättning och uttalstips.
# Hämtas på https://aistudio.google.com/apikey
# Stödjer även GOOGLE_API_KEY och GEMINI_API_KEY som fallback.
GOOGLE_AI_API_KEY=

# Lösenordsskydd för publik deploy. Sätts till valfri sträng — användaren matar in den på /unlock.
# Lämnas tom i lokal dev = ingen access-gate aktiveras.
FLUENTIC_ACCESS_CODE=
